{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"title": {
			"type": "object",
			"properties": {
				"en": {
					"type": "string",
					"minLength": 1
				},
				"ja": {
					"type": "string",
					"minLength": 1
				}
			},
			"required": ["en"],
			"additionalProperties": false
		},
		"prompt": {
			"type": "object",
			"properties": {
				"en": {
					"type": "string",
					"minLength": 1
				},
				"ja": {
					"type": "string",
					"minLength": 1
				}
			},
			"required": ["en"],
			"additionalProperties": false
		},
		"initial": {
			"type": "object",
			"properties": {
				"text": {
					"type": "string"
				},
				"cursor": {
					"type": "integer",
					"minimum": 0,
					"maximum": 9007199254740991
				},
				"mode": {
					"type": "string",
					"const": "normal"
				}
			},
			"required": ["text", "cursor", "mode"],
			"additionalProperties": false
		},
		"expected": {
			"type": "object",
			"properties": {
				"text": {
					"type": "string"
				},
				"cursor": {
					"type": "integer",
					"minimum": 0,
					"maximum": 9007199254740991
				},
				"mode": {
					"type": "string",
					"enum": ["normal", "insert"]
				},
				"yankRegister": {
					"type": "string"
				}
			},
			"required": ["text"],
			"additionalProperties": false
		},
		"constraints": {
			"type": "object",
			"properties": {
				"timeLimitSec": {
					"type": "number",
					"exclusiveMinimum": 0
				},
				"allowedOperators": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"allowedMotions": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"maxKeys": {
					"type": "integer",
					"exclusiveMinimum": 0,
					"maximum": 9007199254740991
				},
				"requireInsertMode": {
					"type": "boolean"
				}
			},
			"required": ["timeLimitSec"],
			"additionalProperties": false
		},
		"hints": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"en": {
						"type": "string",
						"minLength": 1
					},
					"ja": {
						"type": "string",
						"minLength": 1
					}
				},
				"required": ["en"],
				"additionalProperties": false
			}
		},
		"examples": {
			"minItems": 1,
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"tags": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"difficulty": {
			"anyOf": [
				{
					"type": "number",
					"const": 1
				},
				{
					"type": "number",
					"const": 2
				},
				{
					"type": "number",
					"const": 3
				},
				{
					"type": "number",
					"const": 4
				},
				{
					"type": "number",
					"const": 5
				}
			]
		}
	},
	"required": [
		"id",
		"title",
		"prompt",
		"initial",
		"expected",
		"examples",
		"tags",
		"difficulty"
	],
	"additionalProperties": false
}
